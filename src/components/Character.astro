---
import BentoCard from "./BentoCard.astro";
---

<section class="bg-black pb-52">
  <div class="container mx-auto px-3 md:px-10">
    <div class="px-5 py-32">
      <h2 class="font-dbz font-bold text-5xl text-blue-50">Kakaroto</h2>
      <p class="max-w-md font-circular-web text-lg text-blue-50 opacity-50">
        Immerse yourself in a rich and ever-expanding universe where a vibrant
        array of products converge into an interconnected overlay experience on
        your world.
      </p>
    </div>

    <div
      class="border-yellow-200 border-2 relative mb-7 h-96 w-full overflow-hidden rounded-md md:h-[65vh]"
    >
      <BentoCard
        src="videos/feat-goku-2.mp4"
        description="A cross-platform metagame app, turning your activities across Web2 and Web3 games into a rewarding adventure."
        isComingSoon
      />
    </div>

    <div class="grid h-[135vh] w-full grid-cols-2 grid-rows-3 gap-7">
      <div
        class="bento-tilt_1 row-span-1 md:col-span-1 md:row-span-2 border-yellow-200 border-2 rounded-md overflow-hidden"
      >
        <BentoCard
          src="videos/feat-goku.mp4"
          description="An anime and gaming-inspired NFT collection - the IP primed for expansion."
          isComingSoon
        />
      </div>

      <div
        class="bento-tilt_1 row-span-1 ms-32 md:col-span-1 md:ms-0 border-yellow-200 border-2 rounded-md overflow-hidden"
      >
        <BentoCard
          src="videos/feat-goku-3.mp4"
          description="A gamified social hub, adding a new dimension of play to social interaction for Web3 communities."
          isComingSoon
        />
      </div>

      <div
        class="bento-tilt_1 me-14 md:col-span-1 md:me-0 border-yellow-200 border-2 rounded-md overflow-hidden"
      >
        <BentoCard
          src="videos/feat-goku-4.mp4"
          description="A cross-world AI Agent - elevating your gameplay to be more fun and productive."
          isComingSoon
        />
      </div>

      <!-- <div class="bento-tilt_2">
        <div class="flex size-full flex-col justify-between bg-violet-300 p-5">
          <h1 class="bento-title special-font max-w-64 text-black">
            M<b>o</b>re co<b>m</b>ing s<b>o</b>on.
          </h1>
        </div>
      </div> -->

      <div
        class="bento-tilt_2 border-yellow-200 border-2 rounded-md overflow-hidden"
      >
        <video
          src="videos/feat-goku-5.mp4"
          loop
          muted
          autoplay
          class="size-full object-cover object-center"></video>
      </div>
      <div
        class="bento-tilt_2 border-yellow-200 border-2 rounded-md overflow-hidden"
      >
        <video
          src="videos/feat-goku-6.mp4"
          loop
          muted
          autoplay
          class="size-full object-cover object-center"></video>
      </div>
    </div>
  </div>
</section>
