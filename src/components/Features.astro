---
// Importaciones
import BentoCardImg from "./BentoCardImg.astro";
import BentoTilt from "./BentoTilt";
---

<section class="bg-black pb-52">
  <div class="container mx-auto px-3 md:px-10">
    <!-- Encabezado -->
    <div class="px-5 py-32">
      <p class="font-circular-web text-lg text-blue-50">
        Into the Metagame Layer
      </p>
      <p class="max-w-md font-circular-web text-lg text-blue-50 opacity-50">
        Immerse yourself in a rich and ever-expanding universe where a vibrant
        array of products converge into an interconnected overlay experience on
        your world.
      </p>
    </div>

    <!-- Primera Card -->
    <div
      class="relative mb-7 h-[50vh] w-full overflow-hidden rounded-md border-2 border-yellow-300 md:h-[65vh]"
    >
      <img
        src="./img/feat/saiyans.jpg"
        alt="Saiyans Feature"
        class="absolute inset-0 h-full w-full object-cover"
      />
      <!-- <BentoCardImg
        src="./img/feat/saiyans.jpg"
        title="Saiyan NFT"
        description="An anime and gaming-inspired NFT collection - the IP primed for expansion."
        isComingSoon
      /> -->
    </div>

    <!-- Grid Responsive -->
    <div class="grid grid-cols-1 gap-7 md:grid-cols-2 md:grid-rows-3">
      <!-- Card 1 -->
      <div
        class="row-span-1 min-h-[28rem] md:row-span-2 md:min-h-[40rem] rounded-md border-2 border-yellow-300"
      >
        <BentoCardImg
          src="./img/characters/goku.png"
          title="Broli"
          description="An anime and gaming-inspired NFT collection - the IP primed for expansion."
          isComingSoon
        />
      </div>

      <!-- Card 2 -->
      <div
        class="row-span-1 min-h-[28rem] md:row-span-2 md:min-h-[40rem] rounded-md border-2 border-yellow-300"
      >
        <BentoCardImg
          src="./img/characters/vegeta-2.png"
          title="Saiyan Power"
          description="An anime and gaming-inspired NFT collection - the IP primed for expansion."
          isComingSoon
        />
      </div>
      <div
        class="row-span-1 min-h-[28rem] md:row-span-2 md:min-h-[40rem] rounded-md border-2 border-yellow-300"
      >
        <BentoCardImg
          src="./img/characters/gohan-3.webp"
          title="Saiyan Power"
          description="An anime and gaming-inspired NFT collection - the IP primed for expansion."
          isComingSoon
        />
      </div>
      <div
        class="row-span-1 min-h-[28rem] md:row-span-2 md:min-h-[40rem] rounded-md border-2 border-yellow-300"
      >
        <BentoCardImg
          src="./img/characters/trunks.png"
          title="Saiyan Power"
          description="An anime and gaming-inspired NFT collection - the IP primed for expansion."
          isComingSoon
        />
      </div>

      <!-- Texto Extra -->
      <!-- <div
        class="flex min-h-[20rem] flex-col justify-between bg-violet-300 p-5"
      >
        <h1 class="bento-title special-font text-black">
          M<b>o</b>re co<b>m</b>ing s<b>o</b>on.
        </h1>
      </div>

      
      <div class="min-h-[20rem] overflow-hidden">
        <video
          src="./videos/feature-5.mp4"
          loop
          muted
          autoplay
          class="h-full w-full object-cover"></video>
      </div> -->
    </div>
  </div>
</section>
